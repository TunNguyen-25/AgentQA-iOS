#!/usr/bin/env bash
# agentqa-studio — launch the AgentQA Studio dashboard against the current app repo.
#
# Install on PATH (so you can run `agentqa-studio` from any repo):
#   ln -sf "$(pwd)/bin/agentqa-studio" "$HOME/.local/bin/agentqa-studio"
#   # then ensure ~/.local/bin is on your PATH
#
# Env: AGENTQA_STUDIO_PORT overrides the default port (7332).
set -euo pipefail

# Resolve this script's real path, following symlinks, so a PATH symlink
# (e.g. ~/.local/bin/agentqa-studio) still finds the studio/ package.
# BSD readlink (macOS) has no -f, so walk the symlink chain manually.
resolve() {
  local target="$1" dir
  while [ -L "$target" ]; do
    dir="$(cd "$(dirname "$target")" && pwd)"
    target="$(readlink "$target")"
    case "$target" in
      /*) ;;
      *) target="$dir/$target" ;;
    esac
  done
  echo "$target"
}

SELF_PATH="$(resolve "$0")"
SELF="$(cd "$(dirname "$SELF_PATH")" && pwd)"
STUDIO_ROOT="$(cd "$SELF/.." && pwd)"

# App repo = nearest git toplevel from where the user invoked us, else cwd.
REPO="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# Locate the installed write-test scripts for stale/lint (best effort).
MEM_SCRIPTS=""
for cand in \
  "$STUDIO_ROOT/skills/agentqa-write-test/scripts" \
  "$HOME/.claude/skills/agentqa-write-test/scripts" \
  "$REPO/.claude/skills/agentqa-write-test/scripts"; do
  if [ -f "$cand/memory-index.py" ]; then MEM_SCRIPTS="$cand"; break; fi
done

PY="$(command -v python3 || true)"
[ -n "$PY" ] || { echo "agentqa-studio: python3 not found on PATH" >&2; exit 1; }

ARGS=(--repo "$REPO" --port "${AGENTQA_STUDIO_PORT:-7332}" --open)
[ -n "$MEM_SCRIPTS" ] && ARGS+=(--memory-scripts "$MEM_SCRIPTS")

if [ "${1:-}" = "--dry-run" ]; then
  printf 'PYTHONPATH=%s %s -m studio.server' "$STUDIO_ROOT" "$PY"
  printf ' %q' "${ARGS[@]}"
  printf '\n'
  exit 0
fi

exec env PYTHONPATH="$STUDIO_ROOT${PYTHONPATH:+:$PYTHONPATH}" "$PY" -m studio.server "${ARGS[@]}"
