{
  "mcpServers": {
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": ["serve", "--mcp"]
    },
    "basic-memory": {
      "type": "stdio",
      "command": "basic-memory",
      "args": ["--project=__BM_PROJECT__", "mcp"]
    },
    "appium": {
      "type": "stdio",
      "command": "npx",
      "args": ["appium-mcp@__APPIUM_MCP_VERSION__"]
    }
  }
}
