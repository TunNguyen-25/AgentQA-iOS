#!/usr/bin/env python3
"""agent-device shim for the agentqa-write-test eval fixture.

Drives the mock MyTV app in appstate.py. Output shape mirrors the real CLI
(`@e12 [button] label="..." id="..." enabled hittable`) so the agent's habits
transfer. Every invocation is logged to $AGENTQA_EVAL_STATE/calls.jsonl.
"""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import appstate as A  # noqa: E402


def out(s=""):
    print(s)


def snapshot(state, interactive=False, settled=False):
    if settled:
        out("settled: true")
    out(A.render_snapshot(state, interactive_only=interactive))


def main(argv):
    A.log("agent-device", argv)
    if not argv:
        out("agent-device <command> [args]")
        return 0
    cmd = argv[0]
    rest = argv[1:]
    flags = [a for a in rest if a.startswith("-")]
    pos = [a for a in rest if not a.startswith("-")]
    settle = "--settle" in flags
    interactive = "-i" in flags
    state = A.load()

    if cmd in ("devices",):
        out('udid=A1B2C3D4-0000-4000-8000-000000000001 name="iPhone 16 Pro" '
            "os=18.5 state=Booted")
        return 0

    if cmd in ("apps",):
        out("com.vnpt.media.mobileb2c  MyTV")
        out("com.apple.Preferences     Settings")
        return 0

    if cmd in ("open",):
        state = A.load()
        state["opened"] = True
        if not state.get("permission_seen"):
            state["screen"] = "sys_permission"
        elif state["screen"] in ("closed", ""):
            state["screen"] = "intro"
        A.save(state)
        out(f"opened {pos[0] if pos else 'com.vnpt.media.mobileb2c'} on iPhone 16 Pro (18.5)")
        snapshot(state)
        return 0

    if cmd in ("close",):
        state["screen"] = "closed"
        state["opened"] = False
        A.save(state)
        out("session closed")
        return 0

    if cmd in ("snapshot",):
        snapshot(state, interactive=interactive)
        return 0

    if cmd in ("screenshot",):
        spec = A.SCREENS.get(state["screen"], {})
        dest = pos[0] if pos else "screenshot.png"
        Path(dest).write_bytes(b"\x89PNG\r\n\x1a\n<mock screenshot>")
        out(f"saved {dest}")
        # A screenshot is the only way to read the web sheet, so describe it.
        if spec.get("kind") == "web":
            out("visual description (mock): a full-screen white web page titled "
                '"ĐIỀU KHOẢN SỬ DỤNG DỊCH VỤ MyTV", ~8 paragraphs of Vietnamese '
                'legal text, and a blue "Xong" button pinned to the top-right.')
        else:
            out(f"visual description (mock): {spec.get('title', 'unknown screen')}")
        return 0

    if cmd in ("alert",):
        if state["screen"] == "sys_permission":
            out('alert present: "MyTV" Would Like to Send You Notifications')
            out('buttons: "Don\'t Allow", "Allow"')
        else:
            out("no alert present")
        return 0

    if cmd in ("back",):
        if state["screen"] == "terms_web":
            state["screen"] = "login"
        elif state["screen"] == "login":
            state["screen"] = "intro"
        A.save(state)
        snapshot(state)
        return 0

    if cmd in ("press", "click", "tap", "longpress"):
        if not pos:
            out("error: press <x y|@ref|selector>")
            return 2
        target = pos[0]
        el = A.match(target, state)
        if el is None:
            out(f"error: no element matched {target!r} on the current screen")
            out("hint: run `agent-device snapshot -i` and use a ref from that output")
            return 1
        ref, role, label, sym, extra = el
        before = state["screen"]
        _transition(state, el)
        A.save(state)
        out(f"pressed {ref} ({role}) label={label!r}")
        if settle:
            if state["screen"] == before:
                out("settled: true (no structural change)")
                snapshot(state)
            else:
                snapshot(state, settled=True)
        return 0

    if cmd in ("fill", "type"):
        if len(pos) < 2:
            out("error: fill <target> <text>")
            return 2
        target, text = pos[0], pos[1]
        el = A.match(target, state)
        if el is None:
            out(f"error: no element matched {target!r} on the current screen")
            return 1
        ref, role, label, sym, extra = el
        short = sym.split(".")[-1] if sym else ""
        if short == "usernameTextField":
            state["username"] = text
        elif short == "passwordTextField":
            state["password"] = text
        A.save(state)
        shown = text if short != "passwordTextField" else "•" * len(text)
        out(f"filled {ref} with {shown!r}")
        if settle:
            out("settled: true (no structural change)")
            snapshot(state)
        return 0

    if cmd in ("wait",):
        out("ok")
        return 0

    if cmd in ("find", "is", "get"):
        target = pos[-1] if pos else ""
        el = A.match(target, state)
        out("true" if el else "false")
        return 0 if el else 1

    out(f"error: unsupported command {cmd!r} in the eval fixture")
    return 2


def _transition(state, el):
    ref, role, label, sym, extra = el
    sym = sym.split(".")[-1] if sym else None
    screen = state["screen"]
    if screen == "sys_permission":
        state["permission_seen"] = True
        state["screen"] = "intro"
        return
    if screen == "guest_home":
        if sym == "profileTab":
            state["screen"] = "guest_profile"
        return
    if screen == "guest_profile":
        if sym == "btnSignIn":
            state["screen"] = "login"
        return
    if screen == "intro":
        if sym == "btnLogin":
            state["screen"] = "login"
        elif sym == "btnFree":
            state["screen"] = "guest_home"
        return
    if screen == "terms_web":
        if label == "Xong":
            state["screen"] = "login"
        return
    if screen in ("login", "login_error", "login_terms_required"):
        if sym == "checkBoxTermImgView":
            state["terms_checked"] = not state["terms_checked"]
            state["screen"] = "login"
        elif sym == "termsLink":
            state["screen"] = "terms_web"
        elif sym == "btnLogin":
            if not state["terms_checked"]:
                state["screen"] = "login_terms_required"
            elif (state["username"] == A.VALID_USER
                  and state["password"] == A.VALID_PASS):
                state["screen"] = "home"
            else:
                state["screen"] = "login_error"
        return


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
