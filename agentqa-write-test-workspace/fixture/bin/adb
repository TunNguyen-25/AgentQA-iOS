#!/usr/bin/env python3
"""adb shim for the agentqa-write-test eval fixture (Android platform path).

Mirrors the xcrun shim: enough of `adb` to satisfy the Android green-loop
preconditions (`adb devices`, `adb shell pm list packages`) and the reset path
(`adb shell pm clear <pkg>`, which resets the mock app state the same way the iOS
`simctl privacy … reset` does). Every call is logged to calls.jsonl.

The exploration snapshots themselves are still served by the shared agent-device
shim + appstate; this shim only covers the deterministic device/reset plumbing so
the Android config path is exercisable without a real emulator.
"""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import appstate as A  # noqa: E402

SERIAL = "emulator-5554"
PACKAGE = "com.vnpt.media.mobileb2c"


def main(argv):
    A.log("adb", argv)
    # Strip a leading `-s <serial>` target selector if present.
    args = list(argv)
    if len(args) >= 2 and args[0] == "-s":
        args = args[2:]
    if not args:
        print("Android Debug Bridge version 1.0.41 (shim)")
        return 0

    cmd = args[0]

    if cmd == "version":
        print("Android Debug Bridge version 1.0.41 (shim)")
        return 0

    if cmd == "devices":
        print("List of devices attached")
        print(f"{SERIAL}\tdevice")
        return 0

    if cmd == "get-state":
        print("device")
        return 0

    if cmd == "shell":
        sub = args[1:]
        # pm list packages [<filter>]
        if sub[:3] == ["pm", "list", "packages"]:
            flt = sub[3] if len(sub) > 3 else ""
            if not flt or flt in PACKAGE:
                print(f"package:{PACKAGE}")
            return 0
        # pm clear <pkg>  — the data wipe; reset the mock app state.
        if sub[:2] == ["pm", "clear"]:
            A.reset()
            print("Success")
            return 0
        # pm grant / anything else — accept quietly.
        return 0

    # boot/install/uninstall/etc. — no-op success for the fixture.
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
