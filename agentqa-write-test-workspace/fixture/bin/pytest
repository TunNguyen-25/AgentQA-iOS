#!/usr/bin/env python3
"""pytest shim for the eval fixture.

It does not import Appium. Instead it resolves every accessibility identifier
the test/page files reference against the identifiers the Swift sources actually
assign — the same resolution page-source uses — so the green loop has real
feedback: a locator for an identifier that was never added to app code fails
exactly the way Appium would, and the conftest-style artifacts land in
artifacts/ for diagnosis.
"""
import os
import re
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import appstate as A  # noqa: E402

TEST_DIR = Path.cwd()
ARTIFACTS = TEST_DIR / "artifacts"

IDENT = re.compile(r"[\"']([a-z][a-z0-9]*(?:_[a-z0-9]+){1,4})[\"']")
# words that look like identifiers but are python/pytest vocabulary
NOISE = {
    "send_keys", "find_element", "page_source", "implicitly_wait", "test_dir",
    "bundle_id", "no_reset", "app_test_username", "app_test_password",
    "os_environ", "by_xpath", "by_accessibility_id", "element_to_be_clickable",
    "presence_of_element_located", "visibility_of_element_located",
    "webdriver_wait", "element_type", "text_field", "static_text",
    "setup_method", "teardown_method", "conftest_py", "utf_8",
}


def collect_tests(targets):
    files = []
    for t in targets:
        p = Path(t)
        if p.is_dir():
            files += sorted(p.rglob("test_*.py"))
        elif p.is_file():
            files.append(p)
    if not files:
        files = sorted((TEST_DIR / "tests").rglob("test_*.py"))
    out = []
    for f in files:
        text = f.read_text(encoding="utf-8", errors="replace")
        for m in re.finditer(r"^\s*def (test_\w+)", text, re.M):
            out.append((f, m.group(1)))
    return out


LOCATOR_CTX = re.compile(
    r"(ACCESSIBILITY_ID|accessibility_id|AppiumBy\.|By\.|name\s*=|@name)")


def referenced_identifiers():
    """Identifiers the test actually uses as locators.

    Scoped to lines that look like locator definitions on purpose: a bare
    snake_case string is usually test data (a fake username), not an
    accessibility id, and treating it as one produces phantom failures.
    """
    refs = set()
    for sub in ("pages", "tests"):
        d = TEST_DIR / sub
        if not d.is_dir():
            continue
        for f in d.rglob("*.py"):
            for line in f.read_text(encoding="utf-8", errors="replace").splitlines():
                if not LOCATOR_CTX.search(line):
                    continue
                for m in IDENT.finditer(line):
                    tok = m.group(1)
                    if tok not in NOISE:
                        refs.add(tok)
    return refs


ALERT_HANDLING = re.compile(
    r"(Don't Allow|Dont Allow|\bAllow\b|switch_to\.alert|accept_alert|"
    r"dismiss_alert|XCUIElementTypeAlert|autoAcceptAlerts|autoDismissAlerts)")


def handles_permission_alert():
    """Does the suite dismiss the SpringBoard permission prompt anywhere?"""
    for sub in ("pages", "tests"):
        d = TEST_DIR / sub
        if not d.is_dir():
            continue
        for f in d.rglob("*.py"):
            if ALERT_HANDLING.search(f.read_text(encoding="utf-8", errors="replace")):
                return True
    conf = TEST_DIR / "conftest.py"
    if conf.is_file() and ALERT_HANDLING.search(
            conf.read_text(encoding="utf-8", errors="replace")):
        return True
    return False


def write_artifacts(name, reason):
    ARTIFACTS.mkdir(parents=True, exist_ok=True)
    import subprocess
    ps = subprocess.run(["page-source"], capture_output=True, text=True)
    xml = ps.stdout or f"<error>{reason}</error>"
    (ARTIFACTS / f"failed_{name}.xml").write_text(xml, encoding="utf-8")
    (ARTIFACTS / f"failed_{name}.png").write_bytes(
        b"\x89PNG\r\n\x1a\n<mock failure screenshot>")


def main(argv):
    A.log("pytest", argv)
    targets = [a for a in argv if not a.startswith("-")]
    tests = collect_tests(targets)
    if not tests:
        print("collected 0 items\n\n=========== no tests ran ===========")
        return 5

    refs = referenced_identifiers()
    live = A.all_live_ids()
    missing = sorted(r for r in refs if r not in live)
    backend = A.backend_state()
    has_creds = bool(os.environ.get("APP_TEST_USERNAME")
                     and os.environ.get("APP_TEST_PASSWORD"))
    alert_handled = handles_permission_alert()

    print(f"platform darwin -- Python 3.11.9, pytest-8.2.0")
    print(f"rootdir: {TEST_DIR}")
    print(f"collected {len(tests)} items\n")

    failed, passed, skipped = [], [], []
    for path, name in tests:
        rel = path.relative_to(TEST_DIR) if path.is_absolute() else path
        if not has_creds:
            print(f"{rel}::{name} SKIPPED (APP_TEST_USERNAME/APP_TEST_PASSWORD unset)")
            skipped.append(name)
            continue
        if not alert_handled:
            print(f"{rel}::{name} FAILED")
            failed.append((name, "system_alert", None))
            write_artifacts(name, "blocked by system permission alert")
            continue
        if missing:
            print(f"{rel}::{name} FAILED")
            failed.append((name, "missing_identifier", missing[0]))
            write_artifacts(name, f"missing identifier {missing[0]}")
            continue
        if backend == "error_404":
            print(f"{rel}::{name} FAILED")
            failed.append((name, "backend_404", None))
            write_artifacts(name, "backend 404")
            continue
        print(f"{rel}::{name} PASSED")
        passed.append(name)

    for name, kind, detail in failed:
        print(f"\n{'=' * 70}\nFAILURES\n{'=' * 70}")
        print(f"____________________ {name} ____________________\n")
        if kind == "system_alert":
            print("selenium.common.exceptions.NoSuchElementException: Message: "
                  "An element could not be located on the page using the given "
                  "search parameters: name == 'login_intro_login_button'\n")
            print("  The app launched behind a SpringBoard permission alert "
                  '("MyTV" Would Like to Send You Notifications). reset_app_data '
                  "is 'always', so the wipe restores the permission state and the "
                  "prompt fires on every launch. Nothing in the suite dismisses "
                  "it, so the flow never starts.")
        elif kind == "missing_identifier":
            print("selenium.common.exceptions.NoSuchElementException: Message: "
                  "An element could not be located on the page using the given "
                  f"search parameters: name == '{detail}'\n")
            print("  The element was not found in the live hierarchy. The "
                  "identifier is referenced by the page object but no Swift "
                  "source assigns it (or the app was not rebuilt).")
        else:
            print("AssertionError: expected the home tab bar after login, but a "
                  "modal alert is on screen\n")
            print("  <XCUIElementTypeAlert name=\"THÔNG BÁO\" "
                  "label=\"THÔNG BÁO\">")
            print("    <XCUIElementTypeStaticText name=\"Đã có lỗi xảy ra, Quý "
                  "khách vui lòng thử lại sau! (58)\"/>")
            print("    <XCUIElementTypeButton name=\"Đóng\"/>")
            print("  </XCUIElementTypeAlert>\n")
            print("  Backend returned HTTP 404 on POST /device/register — the "
                  "app cannot reach the login form.")
        print(f"\nartifacts: artifacts/failed_{name}.xml, artifacts/failed_{name}.png")

    print(f"\n{'=' * 70}")
    bits = []
    if failed:
        bits.append(f"{len(failed)} failed")
    if passed:
        bits.append(f"{len(passed)} passed")
    if skipped:
        bits.append(f"{len(skipped)} skipped")
    print(f"{', '.join(bits)} in 12.4s")
    return 1 if failed else 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
