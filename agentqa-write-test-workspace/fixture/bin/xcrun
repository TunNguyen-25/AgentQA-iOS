#!/usr/bin/env python3
"""xcrun shim: enough simctl to satisfy the green-loop preconditions and
agentqa-init's reset-app-data.sh. Wiping app data also resets the mock app's
state, so a reset really does put exploration back at first launch.
"""
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import appstate as A  # noqa: E402

UDID = "A1B2C3D4-0000-4000-8000-000000000001"
BUNDLE = "com.vnpt.media.mobileb2c"
CONTAINER_UUID = "9F3C1A20-1111-4222-8333-444455556666"

DEVICES = {
    "devices": {
        "com.apple.CoreSimulator.SimRuntime.iOS-18-5": [{
            "udid": UDID,
            "name": "iPhone 16 Pro",
            "state": "Booted",
            "isAvailable": True,
        }]
    }
}


def main(argv):
    A.log("xcrun", argv)
    if not argv or argv[0] != "simctl":
        print("")
        return 0
    a = argv[1:]
    if not a:
        return 0
    sub = a[0]

    if sub == "list":
        if "-j" in a or "--json" in a:
            print(json.dumps(DEVICES, indent=2))
        else:
            print("== Devices ==")
            print("-- iOS 18.5 --")
            print(f"    iPhone 16 Pro ({UDID}) (Booted)")
        return 0

    if sub == "listapps":
        print(f'"{BUNDLE}" =     {{')
        print('        CFBundleDisplayName = MyTV;')
        print(f'        CFBundleIdentifier = "{BUNDLE}";')
        print("    };")
        return 0

    if sub == "get_app_container":
        # Two halves of simctl's contract that the old shim skipped, and which
        # reset-app-data.sh depends on: a real
        # */Containers/Data/Application/<UUID> path, and a NON-ZERO exit when the
        # app is not installed. Always succeeding with a made-up path meant the
        # script's not-installed branch was never exercised here — and it turned
        # out to be reading the path shape instead of the exit code.
        bundle = a[2] if len(a) > 2 else ""
        if bundle != BUNDLE:
            print("An error was encountered processing the command "
                  "(domain=IDEFoundationErrorDomain, code=1):", file=sys.stderr)
            print(f'No installed application with bundle identifier "{bundle}" '
                  "was found on the device.", file=sys.stderr)
            return 2
        d = A.STATE_DIR / "Containers" / "Data" / "Application" / CONTAINER_UUID
        d.mkdir(parents=True, exist_ok=True)
        print(str(d))
        return 0

    if sub in ("terminate",):
        st = A.load()
        st["screen"] = "closed"
        st["opened"] = False
        A.save(st)
        return 0

    if sub in ("privacy",):
        # `privacy booted reset all <bundle>` — this is the data wipe.
        A.reset()
        return 0

    if sub in ("boot", "shutdown", "install", "uninstall", "launch", "openurl"):
        if sub == "uninstall":
            A.reset()
        return 0

    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
