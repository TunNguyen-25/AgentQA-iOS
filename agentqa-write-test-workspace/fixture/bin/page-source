#!/usr/bin/env python3
"""page-source shim: prints the Appium XCUITest page_source for the current screen.

This is the step-6 tool — the live hierarchy Appium sees, as opposed to
`agent-device snapshot`. Accessibility identifiers appear here only if the Swift
sources actually assign them, which is what makes identifier verification real.
"""
import sys
from pathlib import Path
from xml.sax.saxutils import escape

sys.path.insert(0, str(Path(__file__).resolve().parent))
import appstate as A  # noqa: E402

ROLE_TO_XCUI = {
    "button": "XCUIElementTypeButton",
    "staticText": "XCUIElementTypeStaticText",
    "textinput": "XCUIElementTypeTextField",
    "checkbox": "XCUIElementTypeOther",
    "webview": "XCUIElementTypeWebView",
    "tabbar": "XCUIElementTypeTabBar",
}


def main(argv):
    A.log("page-source", argv)
    state = A.load()
    screen = state["screen"]
    if screen == "closed":
        print("error: no Appium session — the app is not running", file=sys.stderr)
        return 1
    spec = A.SCREENS[screen]
    ids = A.swift_identifiers()
    print('<?xml version="1.0" encoding="UTF-8"?>')
    print('<AppiumAUT>')
    if spec.get("kind") == "system":
        # A permission alert is owned by SpringBoard. It is NOT inside the app's
        # element tree, so no app-code accessibilityIdentifier can ever address
        # it -- it has to be matched by visible label or via the alert API.
        print('  <XCUIElementTypeApplication type="XCUIElementTypeApplication" '
              'name="SpringBoard" label="SpringBoard" enabled="true">')
        print('    <XCUIElementTypeAlert type="XCUIElementTypeAlert" '
              'name="MyTV Would Like to Send You Notifications" '
              'label="MyTV Would Like to Send You Notifications" '
              'enabled="true" visible="true">')
        for _ref, _role, label, _sym, _extra in spec["elements"]:
            if _role == "button":
                print(f'      <XCUIElementTypeButton type="XCUIElementTypeButton" '
                      f'name="{escape(label)}" label="{escape(label)}" '
                      f'enabled="true" visible="true"/>')
        print('    </XCUIElementTypeAlert>')
        print('  </XCUIElementTypeApplication>')
        # the app itself is behind the alert, showing the intro screen
        spec = A.SCREENS["intro"]
    print(f'  <XCUIElementTypeApplication type="XCUIElementTypeApplication" '
          f'name="MyTV" label="MyTV" enabled="true" x="0" y="0" '
          f'width="393" height="852">')
    for ref, role, label, sym, extra in spec["elements"]:
        t = ROLE_TO_XCUI.get(role, "XCUIElementTypeOther")
        aid = ids.get(sym) if sym else None
        name = aid or label
        if role == "textinput" and "secure" in extra:
            t = "XCUIElementTypeSecureTextField"
        print(f'    <{t} type="{t}" name="{escape(name or "")}" '
              f'label="{escape(label or "")}" '
              f'value="" enabled="true" visible="true" '
              f'x="24" y="200" width="345" height="48"/>')
    print('  </XCUIElementTypeApplication>')
    print('</AppiumAUT>')
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
