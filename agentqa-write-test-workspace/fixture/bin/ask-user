#!/usr/bin/env python3
"""ask-user shim: stands in for the human reviewer.

Usage: ask-user "<question>" ["<question 2>" ...]

Logs every question verbatim to $AGENTQA_EVAL_STATE/questions.jsonl and prints
the reviewer's answer. Answers are keyword-routed; anything unrecognised gets a
neutral "no strong preference" so the agent is never blocked, but the question
is still recorded.
"""
import json
import os
import sys
import time
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import appstate as A  # noqa: E402

# Order matters: the first matching bucket wins, so narrow intents
# (permission action, build handoff, approval) are listed before broad ones.
ANSWERS = [
    (("succeed", "success criter", "what does success", "passing look",
      "expected outcome", "happy path", "when does this test succeed"),
     "Success = the user enters a valid username + password, ticks the terms "
     "checkbox, taps Đăng nhập, and lands on the home screen with the bottom "
     "tab bar visible (Trang chủ / Truyền hình / Cá nhân)."),
    (("fail", "failure", "wrong", "invalid cred", "negative"),
     "Failure = the app stays on the login screen and shows the inline red text "
     "\"Sai tên đăng nhập hoặc mật khẩu\" under the password field. It must NOT "
     "bounce back to the intro screen and must not show a modal."),
    (("block", "blocker", "otp", "2fa", "paywall", "rate limit", "test data"),
     "Blockers: (1) a notifications permission prompt on first launch after a "
     "data wipe; (2) the Đăng nhập button stays disabled until the terms "
     "checkbox is ticked. No OTP/2FA on the QA account. Backend is staging and "
     "currently healthy."),
    (("permission", "allow", "don't allow", "dont allow", "system dialog",
      "system alert", "springboard", "prompt appeared", "notification"),
     "Tap \"Don't Allow\" — the suite must run with notifications off so nothing "
     "covers the UI mid-test."),
    (("build", "install", "rebuild", "xcodebuild"),
     "Done — I've built and installed it on the booted simulator. Go ahead."),
    (("environment", "staging", "production", "backend"),
     "staging"),
    (("credential", "account", "username", "password", "env var"),
     "Use the QA account already exported as APP_TEST_USERNAME / APP_TEST_PASSWORD "
     "in your shell. Never write the values into a file."),
    (("lean", "full diagnosis", "pytest-only", "diagnos"),
     "Full diagnosis please."),
    (("approve", "review", "look good", "ok to", "shall i", "should i"),
     "Looks good, go ahead."),
    (("objective", "regression", "exploratory", "accessibility"),
     "Happy path first, plus the invalid-credentials negative case."),
    (("precondition", "logged in", "premium", "feature flag"),
     "Start logged out; no feature flags needed."),
    (("risk", "concern", "recent refactor"),
     "The login view was refactored last sprint — the terms checkbox is new."),
]

NEUTRAL = "No strong preference — use your best judgement."


def answer_for(q: str) -> str:
    low = q.lower()
    for keys, ans in ANSWERS:
        if any(k in low for k in keys):
            return ans
    return NEUTRAL


def main(argv):
    if not argv:
        print("usage: ask-user \"<question>\" [...]", file=sys.stderr)
        return 2
    state_dir = A.STATE_DIR
    state_dir.mkdir(parents=True, exist_ok=True)
    with (state_dir / "questions.jsonl").open("a", encoding="utf-8") as fh:
        for q in argv:
            ans = answer_for(q)
            fh.write(json.dumps(
                {"ts": time.time(), "question": q, "answer": ans},
                ensure_ascii=False) + "\n")
            print(f"Q: {q}")
            print(f"A: {ans}")
            print()
    A.log("ask-user", argv, {"count": len(argv)})
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
