#!/usr/bin/env python3
"""ask-user shim: stands in for the human reviewer.

Usage: ask-user "<question>" ["<question 2>" ...]

Logs every question verbatim to $AGENTQA_EVAL_STATE/questions.jsonl and prints
the reviewer's answer, so the agent is never blocked but every question is
still on the record for grading.

Routing
-------
The agent does not ask keywords, it asks paragraphs: a label that states the
intent ("SUCCESS —", "BLOCKERS —", "BUILD HANDOFF …") followed by a screenful of
context that inevitably names every neighbouring topic. A success question
quotes the QA credentials, a permission question says the alert "blocks" the
flow, a build handoff lists a test called `test_login_wrong_password`. Under
first-substring-wins the answer went to whichever unrelated word sat earliest in
the table, and the agent burned a round re-asking something it had already
asked — all six iteration-3 runs hit that, and it cost both arms the
batched-round assertion.

So route on evidence rather than on the first hit:

  * signals match as words, not substrings, so `pass` does not fire on
    `password` and `allow` does not fire on `not allowed to guess`;
  * each bucket separates strong signals — phrasing only this intent uses —
    from weak ones, which are topical but shared with the neighbours;
  * a signal in the opening clause counts triple, because the label before the
    first dash or colon is where the agent states what it is asking;
  * the top-scoring bucket answers, and a second bucket carrying strong
    evidence of its own answers too, the way a person replying to a two-part
    question answers both parts instead of picking one.

The label is evidence, not a verdict: a question titled "BLOCKER ESCALATION"
that ends "'Allow' or 'Don't Allow'?" is a permission question, and the
choose-a-button phrasing outweighs the heading. That is deliberate — routing on
the heading alone reproduces the original bug in a new place.

One exception earns its own rule. When the agent follows up ("Re-asking Q1 —
your answer covered the credentials, but not the success criterion…") the
opening clause quotes the *previous* answer instead of announcing a new intent,
so boosting it re-delivers the answer the agent just told us was wrong. A
recap opener therefore forfeits the boost and the question is scored flat.

A question matching nothing gets a neutral reply, which reads as the reviewer
dodging. When that shows up in a transcript, widen the signals rather than
letting the agent stall.
"""
import json
import re
import sys
import time
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import appstate as A  # noqa: E402

STRONG, WEAK, LEDE_BOOST = 3, 1, 3

# A second bucket is answered when the question announces two intents: it has to
# be named in the opening clause AND carry evidence worth a boosted strong hit.
# Both halves matter — the floor alone lets `test_login_wrong_password`, listed
# in a build handoff, drag the failure criterion along, and the naming alone
# would answer every topic a question mentions in passing.
SECOND_ANSWER_FLOOR = STRONG * LEDE_BOOST

# The opening clause: text up to the first separator far enough in to have a
# label before it. The floor only has to clear list numbering ("1.", "(2)."), and
# a low one matters: at 12 the dash in "1) SUCCESS —" lands too early to count,
# the whole first 120 characters become the label, and the body's passing mention
# of the QA account picks up a boost it has not earned.
MIN_LEDE, MAX_LEDE = 6, 120
_SEPARATORS = re.compile(r"—|–|--|[:?.\n]")

# Openers that quote the last answer instead of announcing a new intent. Only the
# start of the question is searched: a question can say "you said" halfway down
# without being a follow-up.
RECAP_WINDOW = 240
_RECAP_MARKERS = (
    "re asking", "reasking", "re ask", "follow up on", "followup on",
    "your answer", "your last answer", "your reply", "your last reply",
    "that reply", "your last message", "the answer i got", "the reply i got",
    "the replies came back", "you said", "restated",
    "did not get a direct answer", "was not answered", "not answered in",
)


# --------------------------------------------------------------------------
# buckets
# --------------------------------------------------------------------------
#
# Order breaks ties only; scoring decides almost everything. Keep the more
# specific, more actionable intents first so a genuine tie resolves toward the
# answer the agent can act on.

BUCKETS = [
    dict(
        name="permission",
        # A permission question is one that asks the reviewer to pick a button.
        # Naming the buttons is what separates it from the blockers question
        # that merely mentions the same prompt exists.
        strong=("dont allow", "allow or", "or allow", "which button",
                "should i tap", "tap allow", "tap dont allow", "which action",
                "allow or deny", "exactly one of", "springboard", "system alert",
                "system dialog", "system prompt"),
        weak=("permission", "notification", "notifications", "alert", "prompt",
              "dialog", "popup", "button"),
        answer='Tap "Don\'t Allow" — the suite must run with notifications off '
               "so nothing covers the UI mid-test.",
    ),
    dict(
        name="build",
        strong=("build handoff", "xcodebuild", "have you built", "rebuild",
                "build and install", "installed the build", "install the build",
                "ready for me to", "let me know when"),
        weak=("build", "install", "installed", "handoff"),
        answer="Done — I've built and installed it on the booted simulator. Go ahead.",
    ),
    dict(
        name="approval",
        strong=("review checkpoint", "do you approve", "approve", "sign off",
                "ok to proceed", "looks good", "look good", "shall i",
                "should i proceed", "tell me to do otherwise",
                "confirm that is what you want", "or send changes",
                "want changes"),
        weak=("review", "checkpoint", "confirm"),
        answer="Looks good, go ahead.",
    ),
    dict(
        name="divergence",
        # The doc-vs-build conflict the intent-layer evals are built around.
        strong=("divergence", "diverges", "diverge", "disagrees", "contradicts",
                "contrary to", "no longer matches", "does not match",
                "doesnt match", "spec vs", "vs live", "out of date", "stale",
                "which one wins"),
        weak=("srd", "spec", "doc", "docs"),
        answer="The shipped build wins — the doc has drifted. Assert what you "
               "observed live, leave the doc-only behaviour out of scope, and "
               "note the gap in your summary so I can get the SRD corrected. "
               "Do not change app behaviour to match the doc.",
    ),
    dict(
        name="success",
        strong=("success", "successful", "successfully", "succeed", "succeeds",
                "success criteria", "success criterion", "happy path",
                "expected outcome", "counts as passing", "what does passing",
                "test to pass", "this test pass", "test passes",
                "pass look like"),
        weak=("pass", "passes", "passing", "green", "home screen"),
        answer="Success = the user enters a valid username + password, ticks the "
               "terms checkbox, taps Đăng nhập, and lands on the home screen "
               "with the bottom tab bar visible (Trang chủ / Truyền hình / Cá nhân).",
    ),
    dict(
        name="failure",
        strong=("failure", "fail", "fails", "failing", "failure criterion",
                "failure criteria", "real failure", "negative case",
                "negative test", "wrong credentials", "wrong password",
                "bad password", "invalid credentials", "invalid password",
                "loosen the assertion", "weaken the assertion"),
        weak=("wrong", "invalid", "error", "negative"),
        answer="Failure = the app stays on the login screen and shows the inline "
               'red text "Sai tên đăng nhập hoặc mật khẩu" under the password '
               "field. It must NOT bounce back to the intro screen and must not "
               "show a modal.",
    ),
    dict(
        name="blockers",
        strong=("blocker", "blockers", "what could block", "what could stop",
                "stop this test", "prevent the test", "otp", "2fa", "paywall",
                "rate limit", "rate limiting", "test data"),
        weak=("block", "blocks", "blocked", "blocking"),
        answer="Blockers: (1) a notifications permission prompt on first launch "
               "after a data wipe; (2) the Đăng nhập button stays disabled until "
               "the terms checkbox is ticked. No OTP/2FA on the QA account. "
               "Backend is staging and currently healthy.",
    ),
    dict(
        name="entry_point",
        # Answered concretely rather than left neutral: a reviewer who knows the
        # app has an opinion here, and a shrug reads as a dodge and invites a
        # re-ask.
        strong=("entry point", "entry points", "entry path", "which route",
                "enter through", "reach the login", "reached from",
                "which caller"),
        weak=("caller", "callers", "route", "cold start"),
        answer="Cold start through the intro screen — that is the path a real "
               "first-time user takes, and it is the one the suite should cover. "
               "The profile-tab route lands on the same LoginViewController; "
               "leave it for a later test.",
    ),
    dict(
        name="credentials",
        strong=("which account", "what credentials", "which credentials",
                "test account", "qa account", "credentials to use",
                "are those exported", "already exported", "env var", "env vars",
                "environment variable", "environment variables", "hardcode",
                "hard code"),
        weak=("credential", "credentials", "username", "password", "account",
              "login as"),
        answer="Use the QA account already exported as APP_TEST_USERNAME / "
               "APP_TEST_PASSWORD in your shell. Never write the values into a file.",
    ),
    dict(
        name="environment",
        strong=("which environment", "what environment", "which backend",
                "staging or production", "which server", "environment",
                "backend", "staging", "production"),
        weak=("env", "server", "endpoint"),
        answer="staging",
    ),
    dict(
        name="diagnosis",
        strong=("full diagnosis", "pytest only", "pytest-only", "lean run",
                "diagnose", "diagnosis"),
        weak=("lean", "triage"),
        answer="Full diagnosis please.",
    ),
    dict(
        name="objectives",
        strong=("regression suite", "exploratory", "accessibility audit",
                "what should this test cover", "which cases", "test objectives"),
        weak=("regression", "objective", "objectives", "scope"),
        answer="Happy path first, plus the invalid-credentials negative case.",
    ),
    dict(
        name="preconditions",
        strong=("precondition", "preconditions", "already logged in",
                "feature flag", "feature flags", "premium account"),
        weak=("logged in", "premium", "starting state"),
        answer="Start logged out; no feature flags needed.",
    ),
    dict(
        name="risks",
        strong=("recent refactor", "anything risky", "known issues",
                "anything i should worry"),
        weak=("risk", "risks", "concern", "concerns", "refactor"),
        answer="The login view was refactored last sprint — the terms checkbox is new.",
    ),
]

ANSWERS = {b["name"]: b["answer"] for b in BUCKETS}

NEUTRAL = "No strong preference — use your best judgement."


# --------------------------------------------------------------------------
# routing
# --------------------------------------------------------------------------

_PATTERNS = {}


def _pattern(phrase: str):
    """`phrase` as a whole-word match against normalised text."""
    rx = _PATTERNS.get(phrase)
    if rx is None:
        rx = _PATTERNS[phrase] = re.compile(
            r"\b" + r"\s+".join(re.escape(w) for w in phrase.split()) + r"\b"
        )
    return rx


def normalize(text: str) -> str:
    """Lowercase and reduce to words separated by single spaces.

    `DONT_ALLOW`, `Don't Allow` and `dont-allow` are the same answer to the same
    question; word-boundary matching only sees that if they normalise together.
    """
    text = text.lower().replace("'", "").replace("’", "")
    return re.sub(r"[^a-z0-9]+", " ", text)


def lede_of(question: str) -> str:
    """The opening clause — where the agent states which question this is."""
    for m in _SEPARATORS.finditer(question):
        if m.start() >= MIN_LEDE:
            return question[:min(m.start(), MAX_LEDE)]
    return question[:MAX_LEDE]


def is_recap(question: str) -> bool:
    """Does the question open by quoting the previous answer back at us?"""
    opening = normalize(question)[:RECAP_WINDOW]
    return any(_pattern(m).search(opening) for m in _RECAP_MARKERS)


def score(bucket: dict, body: str, lede: str, boost: int) -> tuple:
    """Evidence for one bucket: (total score, score from the opening clause).

    `lede` is a prefix of `body`, so each signal counts once — at the boosted
    weight when it lands in the opening clause. The unboosted lede score comes
    back too, because "is this bucket named in the label?" is what decides
    whether a second answer is warranted.
    """
    total = lede_total = 0
    for key, weight in (("strong", STRONG), ("weak", WEAK)):
        for phrase in bucket.get(key, ()):
            rx = _pattern(phrase)
            if rx.search(lede):
                total += weight * boost
                lede_total += weight
            elif rx.search(body):
                total += weight
    return total, lede_total


def _ranked(question: str):
    """Buckets ordered best-first, as (total, lede_total, index, name)."""
    body, lede = normalize(question), normalize(lede_of(question))
    # A recap opener is a quotation, not a label, so it forfeits the boost.
    boost = 1 if is_recap(question) else LEDE_BOOST
    rows = []
    for i, b in enumerate(BUCKETS):
        total, lede_total = score(b, body, lede, boost)
        rows.append((total, lede_total, i, b["name"]))
    return sorted(rows, key=lambda r: (-r[0], r[2]))


def scores(question: str) -> dict:
    """Bucket name -> evidence score. Exposed for tests and debugging."""
    return {name: total for total, _, _, name in _ranked(question)}


def route(question: str):
    """Buckets that should answer this question, best first (0, 1 or 2 of them)."""
    ranked = _ranked(question)
    top, _, _, name = ranked[0]
    if top <= 0:
        return []
    picked = [name]
    runner_up, runner_up_lede, _, second = ranked[1]
    if runner_up >= SECOND_ANSWER_FLOOR and runner_up_lede > 0:
        picked.append(second)
    return picked


def answer_for(question: str, names=None) -> str:
    names = route(question) if names is None else names
    if not names:
        return NEUTRAL
    return "\n\n".join(ANSWERS[n] for n in names)


def main(argv):
    if not argv:
        print("usage: ask-user \"<question>\" [...]", file=sys.stderr)
        return 2
    if argv[0] == "--explain":  # debugging aid: why did this question route there?
        for q in argv[1:]:
            ranked = sorted(scores(q).items(), key=lambda kv: -kv[1])
            print(f"Q: {q[:120]}")
            print(f"   route: {route(q) or ['(neutral)']}")
            print("   scores: " + ", ".join(f"{n}={s}" for n, s in ranked if s))
            print()
        return 0
    state_dir = A.STATE_DIR
    state_dir.mkdir(parents=True, exist_ok=True)
    with (state_dir / "questions.jsonl").open("a", encoding="utf-8") as fh:
        for q in argv:
            buckets = route(q)
            ans = answer_for(q, buckets)
            fh.write(json.dumps(
                {"ts": time.time(), "question": q, "answer": ans,
                 "buckets": buckets},
                ensure_ascii=False) + "\n")
            print(f"Q: {q}")
            print(f"A: {ans}")
            print()
    A.log("ask-user", argv, {"count": len(argv)})
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
