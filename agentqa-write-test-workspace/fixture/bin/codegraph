}


def main(argv):
    A.log("codegraph", argv)
    if not argv:
        print("codegraph <init|explore|status> ...")
        return 0
    cmd = argv[0]
    if cmd == "init":
        time.sleep(1.0)  # indexing is CPU-heavy; make the cost visible
        (A.REPO / ".codegraph").mkdir(exist_ok=True)
        (A.REPO / ".codegraph" / "index.db").write_text("mock index\n", encoding="utf-8")
        print("codegraph: indexed 9 files, 34 symbols, 51 edges -> .codegraph/index.db")
        return 0
    if cmd == "status":
        print("index present" if (A.REPO / ".codegraph").is_dir() else "no index")
        return 0
    if cmd == "explore":
        if not (A.REPO / ".codegraph").is_dir():
            print("codegraph: no index found — run `codegraph init` first")
            return 1
        query = " ".join(argv[1:]).lower()
        hits = [v for k, v in MAP.items() if k in query]
        if not hits:
            hits = [MAP["login"]]
        for h in hits:
            print(h.strip())
        return 0
    print(f"codegraph: unsupported command {cmd!r}")
    return 2


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
