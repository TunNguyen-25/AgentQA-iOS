#!/usr/bin/env python3
"""codegraph shim: canned symbol map for the mock MyTV sources."""
import sys
import time
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import appstate as A  # noqa: E402

MAP = {
